# spike-rtic — project-local environment (loaded by direnv)
#
# This file is auto-loaded when you cd into the project directory
# and auto-unloaded when you leave.  Works in any shell, any IDE
# that inherits the shell environment.
#
# First-time setup:
#   sudo apt install direnv
#   echo 'eval "$(direnv hook bash)"' >> ~/.bashrc
#   direnv allow          # run once in this directory

# ── Project root (canonical, no guessing) ──
export PROJECT_ROOT="$(pwd)"

# ── Rust toolchain ──
# Note: CARGO_BUILD_TARGET is NOT set here because it would break
# host-side tools (xtask, helper scripts).  The firmware target is
# set in .cargo/config.toml instead.

# ── Helper tools on PATH ──
# So you can run `upload_demo.py` etc. without full paths
PATH_add helper-tools

# ── Hub serial port overrides (optional) ──
# Uncomment to hardcode ports instead of auto-detect:
# export SPIKE_SHELL_PORT=/dev/spike-shell
# export SPIKE_GDB_PORT=/dev/spike-gdb

# ── Socat GDB bridge port ──
export SPIKE_GDB_TCP_PORT=3333
