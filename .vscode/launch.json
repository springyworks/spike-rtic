{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug gdb_exercise (LLDB)",
            "type": "lldb",
            "request": "custom",
            "targetCreateCommands": [
                "target create ${workspaceFolder}/examples/hub-ram-demos/target/thumbv7em-none-eabihf/release/examples/gdb_exercise"
            ],
            "processCreateCommands": [
                "process connect --plugin gdb-remote serial:///tmp/spike-hub?baud=115200"
            ],
            "sourceMap": {
                "/": "/"
            },
            "preLaunchTask": "xtask-debug-gdb-exercise"
        },
        {
            "name": "Debug gdb_simple (LLDB)",
            "type": "lldb",
            "request": "custom",
            "targetCreateCommands": [
                "target create ${workspaceFolder}/examples/hub-ram-demos/target/thumbv7em-none-eabihf/release/examples/gdb_simple"
            ],
            "processCreateCommands": [
                "process connect --plugin gdb-remote serial:///tmp/spike-hub?baud=115200"
            ],
            "sourceMap": {
                "/": "/"
            },
            "preLaunchTask": "xtask-debug-gdb-simple"
        },
        {
            "name": "Debug demo (LLDB, pick name)",
            "type": "lldb",
            "request": "custom",
            "targetCreateCommands": [
                "target create ${workspaceFolder}/examples/hub-ram-demos/target/thumbv7em-none-eabihf/release/examples/${input:demoName}"
            ],
            "processCreateCommands": [
                "process connect --plugin gdb-remote serial:///tmp/spike-hub?baud=115200"
            ],
            "sourceMap": {
                "/": "/"
            },
            "preLaunchTask": "xtask-debug-pick"
        },
        {
            "name": "Debug gdb_exercise (GDB)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/examples/hub-ram-demos/target/thumbv7em-none-eabihf/release/examples/gdb_exercise",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb-multiarch",
            "miDebuggerServerAddress": "/tmp/spike-hub",
            "stopAtEntry": false,
            "setupCommands": [
                { "text": "set remotetimeout 10" },
                { "text": "set mem inaccessible-by-default off" },
                { "text": "set architecture arm" },
                { "text": "set arm force-mode thumb" }
            ],
            "sourceFileMap": {
                "examples": "${workspaceFolder}/examples/hub-ram-demos/examples",
                "src": "${workspaceFolder}/examples/hub-ram-demos/src"
            },
            "preLaunchTask": "xtask-debug-gdb-exercise"
        },
        {
            "name": "Debug gdb_simple (GDB)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/examples/hub-ram-demos/target/thumbv7em-none-eabihf/release/examples/gdb_simple",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb-multiarch",
            "miDebuggerServerAddress": "/tmp/spike-hub",
            "stopAtEntry": false,
            "setupCommands": [
                { "text": "set remotetimeout 10" },
                { "text": "set mem inaccessible-by-default off" },
                { "text": "set architecture arm" },
                { "text": "set arm force-mode thumb" }
            ],
            "sourceFileMap": {
                "examples": "${workspaceFolder}/examples/hub-ram-demos/examples",
                "src": "${workspaceFolder}/examples/hub-ram-demos/src"
            },
            "preLaunchTask": "xtask-debug-gdb-simple"
        }
    ],
    "inputs": [
        {
            "id": "demoName",
            "type": "promptString",
            "description": "Demo name (e.g. gdb_exercise, color_seeker, dual_motors)"
        }
    ]
}
