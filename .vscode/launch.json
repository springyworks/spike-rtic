{
    // SPIKE RTIC — Debug Launch Configurations
    //
    // Hub connection: xtask handles port detection, auto-kill blockers,
    // hub mode probing (Shell/RSP/Unknown), and recovery. If no
    // /dev/ttyACM* is found, the preLaunchTask will fail with a clear
    // "LEGO SPIKE hub not found" message.
    //
    // NOTE: "request": "custom" warnings are false positives — it's a
    // valid CodeLLDB extension value for raw target/process commands.
    "version": "0.2.0",
    "configurations": [

        // ── Open-editor: debug whichever demo .rs file is active ──
        {
            "name": "Debug open file (LLDB)",
            "type": "lldb",
            "request": "custom",
            "initCommands": [
                "settings set plugin.process.gdb-remote.packet-timeout 30",
                "settings set target.default-arch thumbv7em"
            ],
            "targetCreateCommands": [
                "target create ${workspaceFolder}/examples/hub-ram-demos/target/thumbv7em-none-eabihf/release/examples/${fileBasenameNoExtension}"
            ],
            "processCreateCommands": [
                "gdb-remote localhost:3333"
            ],
            "sourceMap": { "/": "/" },
            "preLaunchTask": "xtask-debug-open-file"
        },
        {
            "name": "Debug open file (GDB)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/examples/hub-ram-demos/target/thumbv7em-none-eabihf/release/examples/${fileBasenameNoExtension}",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb-multiarch",
            "stopAtEntry": false,
            "setupCommands": [
                { "text": "set remotetimeout 10" },
                { "text": "set serial baud 115200" },
                { "text": "set mem inaccessible-by-default off" },
                { "text": "set architecture arm" },
                { "text": "set arm force-mode thumb" },
                { "text": "target remote /tmp/spike-gdb" }
            ],
            "sourceFileMap": {
                "examples": "${workspaceFolder}/examples/hub-ram-demos/examples",
                "src": "${workspaceFolder}/examples/hub-ram-demos/src"
            },
            "preLaunchTask": "xtask-debug-open-file"
        },

        // ── Prompted: pick any demo by name ──
        {
            "name": "Debug demo (LLDB)",
            "type": "lldb",
            "request": "custom",
            "initCommands": [
                "settings set plugin.process.gdb-remote.packet-timeout 30",
                "settings set target.default-arch thumbv7em"
            ],
            "targetCreateCommands": [
                "target create ${workspaceFolder}/examples/hub-ram-demos/target/thumbv7em-none-eabihf/release/examples/${input:demoName}"
            ],
            "processCreateCommands": [
                "gdb-remote localhost:3333"
            ],
            "sourceMap": { "/": "/" },
            "preLaunchTask": "xtask-debug-pick"
        },
        {
            "name": "Debug demo (GDB)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/examples/hub-ram-demos/target/thumbv7em-none-eabihf/release/examples/${input:demoName}",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb-multiarch",
            "stopAtEntry": false,
            "setupCommands": [
                { "text": "set remotetimeout 10" },
                { "text": "set serial baud 115200" },
                { "text": "set mem inaccessible-by-default off" },
                { "text": "set architecture arm" },
                { "text": "set arm force-mode thumb" },
                { "text": "target remote /tmp/spike-gdb" }
            ],
            "sourceFileMap": {
                "examples": "${workspaceFolder}/examples/hub-ram-demos/examples",
                "src": "${workspaceFolder}/examples/hub-ram-demos/src"
            },
            "preLaunchTask": "xtask-debug-pick"
        },

        // ── Quick-launch shortcuts (no prompt, just F5) ──
        {
            "name": "Quick: gdb_simple (LLDB)",
            "type": "lldb",
            "request": "custom",
            "initCommands": [
                "settings set plugin.process.gdb-remote.packet-timeout 30",
                "settings set target.default-arch thumbv7em"
            ],
            "targetCreateCommands": [
                "target create ${workspaceFolder}/examples/hub-ram-demos/target/thumbv7em-none-eabihf/release/examples/gdb_simple"
            ],
            "processCreateCommands": [
                "gdb-remote localhost:3333"
            ],
            "sourceMap": { "/": "/" },
            "preLaunchTask": "xtask-debug-gdb-simple"
        },
        {
            "name": "Quick: gdb_exercise (LLDB)",
            "type": "lldb",
            "request": "custom",
            "initCommands": [
                "settings set plugin.process.gdb-remote.packet-timeout 30",
                "settings set target.default-arch thumbv7em"
            ],
            "targetCreateCommands": [
                "target create ${workspaceFolder}/examples/hub-ram-demos/target/thumbv7em-none-eabihf/release/examples/gdb_exercise"
            ],
            "processCreateCommands": [
                "gdb-remote localhost:3333"
            ],
            "sourceMap": { "/": "/" },
            "preLaunchTask": "xtask-debug-gdb-exercise"
        },
        {
            // "name": "Quick: reg_dump (LLDB)",
            "type": "lldb",
            "request": "custom",
            "initCommands": [
                "settings set plugin.process.gdb-remote.packet-timeout 30",
                "settings set target.default-arch thumbv7em"
            ],
            "targetCreateCommands": [
                "target create ${workspaceFolder}/examples/hub-ram-demos/target/thumbv7em-none-eabihf/release/examples/reg_dump"
            ],
            "processCreateCommands": [
                "gdb-remote localhost:3333"
            ],
            "sourceMap": { "/": "/" },
            "preLaunchTask": "xtask-debug-reg-dump"
        }
    ],
    "inputs": [
        {
            "id": "demoName",
            "type": "promptString",
            "description": "Demo name (e.g. gdb_simple, gdb_exercise, color_seeker, dual_motors)"
        }
    ]
}
