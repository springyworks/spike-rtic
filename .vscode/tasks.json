{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "xtask-debug-gdb-exercise",
			"type": "shell",
			"command": "cargo",
			"args": ["run", "--", "debug", "gdb_exercise"],
			"options": { "cwd": "${workspaceFolder}/examples/hub-ram-demos/xtask" },
			"presentation": { "reveal": "always", "panel": "shared" },
			"problemMatcher": "$rustc"
		},
		{
			"label": "xtask-debug-gdb-simple",
			"type": "shell",
			"command": "cargo",
			"args": ["run", "--", "debug", "gdb_simple"],
			"options": { "cwd": "${workspaceFolder}/examples/hub-ram-demos/xtask" },
			"presentation": { "reveal": "always", "panel": "shared" },
			"problemMatcher": "$rustc"
		},
		{
			"label": "xtask-debug-pick",
			"type": "shell",
			"command": "cargo",
			"args": ["run", "--", "debug", "${input:demoName}"],
			"options": { "cwd": "${workspaceFolder}/examples/hub-ram-demos/xtask" },
			"presentation": { "reveal": "always", "panel": "shared" },
			"problemMatcher": "$rustc"
		},
		{
			"label": "xtask-upload",
			"type": "shell",
			"command": "cargo",
			"args": ["run", "--", "upload", "${input:demoName}"],
			"options": { "cwd": "${workspaceFolder}/examples/hub-ram-demos/xtask" },
			"presentation": { "reveal": "always", "panel": "shared" },
			"problemMatcher": "$rustc"
		},
		{
			"label": "xtask-build",
			"type": "shell",
			"command": "cargo",
			"args": ["run", "--", "build", "${input:demoName}"],
			"options": { "cwd": "${workspaceFolder}/examples/hub-ram-demos/xtask" },
			"group": "build",
			"presentation": { "reveal": "always", "panel": "shared" },
			"problemMatcher": "$rustc"
		},
		{
			"label": "build-firmware",
			"type": "shell",
			"command": "cd ${workspaceFolder} && cargo build --release 2>&1 | tail -40"
		},
		{
			"label": "free-port",
			"type": "shell",
			"command": "cargo",
			"args": ["run", "--", "free-port"],
			"options": { "cwd": "${workspaceFolder}/examples/hub-ram-demos/xtask" },
			"presentation": { "reveal": "always", "panel": "shared" },
			"problemMatcher": []
		},
		{
			"label": "build-spike-rtic",
			"type": "shell",
			"command": "cargo build --release 2>&1"
		}
	],
	"inputs": [
		{
			"id": "demoName",
			"type": "promptString",
			"description": "Demo name (e.g. gdb_exercise, color_seeker, dual_motors)"
		}
	]
}