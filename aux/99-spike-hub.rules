# SPIKE Prime Hub — dual CDC-ACM stable symlinks
#
# Install:
#   sudo cp aux/99-spike-hub.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
#
# After plugging in the hub:
#   /dev/spike-shell  → ttyACMx (shell lifeline, always available)
#   /dev/spike-gdb    → ttyACMy (GDB RSP, dedicated debug port)
#
# Interface 00 = first CDC function (shell)
# Interface 02 = second CDC function (GDB RSP)

SUBSYSTEM=="tty", ATTRS{idVendor}=="0694", ATTRS{idProduct}=="0042", ENV{ID_USB_INTERFACE_NUM}=="00", SYMLINK+="spike-shell", MODE="0666"
SUBSYSTEM=="tty", ATTRS{idVendor}=="0694", ATTRS{idProduct}=="0042", ENV{ID_USB_INTERFACE_NUM}=="02", SYMLINK+="spike-gdb", MODE="0666"

# DFU mode (for flashing firmware)
SUBSYSTEM=="usb", ATTRS{idVendor}=="0694", ATTRS{idProduct}=="0011", MODE="0666"
